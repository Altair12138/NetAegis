# ============================================================
# NetAegis 环境配置模板
# 使用方式: cp .env.example .env && 填写真实值
# 注意: .env 文件包含敏感信息，不要提交到版本库！
# ============================================================

# ---------- 部署环境 ----------
# production 下 API_TOKEN 必填，否则服务拒绝启动
ENVIRONMENT=production

# ---------- 设备凭据 ----------
# 默认凭据 profile（所有设备共用，也可在 inventory/devices.csv 中按设备覆盖）
CRED_DEFAULT_USERNAME=netdevops
CRED_DEFAULT_PASSWORD=ChangeMePlease!
CRED_DEFAULT_ENABLE=

# 备份专用凭据（可选，留空则使用默认凭据）
CRED_BACKUP_USERNAME=
CRED_BACKUP_PASSWORD=

# ---------- 存储 ----------
# Docker 部署中建议保持默认值，数据通过 volume 持久化
DB_URL=sqlite:///./data/inspection.db
RESULT_DIR=/app/results
LOG_DIR=/app/logs

# ---------- 运行参数 ----------
# 默认并发数（同时巡检的设备数量）
DEFAULT_CONCURRENCY=20
# 单条命令超时（秒）
DEFAULT_CMD_TIMEOUT=60
# 单设备整体超时（秒），0 表示不限制
DEVICE_RUN_TIMEOUT=0

# ---------- 日志 ----------
LOG_LEVEL=INFO
# text 或 json（json 适合日志收集系统）
LOG_FORMAT=text

# ---------- SSH 兼容性 ----------
# 设为 true 允许旧版华为设备的 RSA/SHA1 密钥交换
SSH_ALLOW_LEGACY_RSA=false
# 设为 true 开启 Netmiko SSH 调试日志
SSH_DEBUG=false

# ---------- API ----------
# Bearer Token 认证，production 下必填
# 生成方式: echo -n 'your-secret' | base64
API_TOKEN=ChangeMeToASecretBase64Token==
API_HOST=0.0.0.0
API_PORT=8080

# ---------- 时区 ----------
TZ=Asia/Shanghai
