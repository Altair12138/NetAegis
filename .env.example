# 复制为 .env 后填写真实值。.env 不要提交到版本库。

# 默认凭据 profile
CRED_DEFAULT_USERNAME=netdevops
CRED_DEFAULT_PASSWORD=Python@123!
CRED_DEFAULT_ENABLE=

# 备份专用凭据（可选）
CRED_BACKUP_USERNAME=
CRED_BACKUP_PASSWORD=

# 存储
DB_URL=sqlite:///./inspection.db
RESULT_DIR=./results        # 相对路径基于 BASE_DIR
LOG_DIR=./logs              # 相对路径基于 BASE_DIR
# 备份目录默认与 RESULT_DIR 同级（./backups）

# 项目根目录（用于解析相对路径，如 inventory/devices.csv）
BASE_DIR=.

# 默认并发
DEFAULT_CONCURRENCY=20

# 命令超时（秒）
DEFAULT_CMD_TIMEOUT=60

# 兼容老旧设备（只支持 ssh-rsa）
SSH_ALLOW_LEGACY_RSA=false

# SSH 调试日志（输出到 logs/paramiko.log）
SSH_DEBUG=false

# API
API_TOKEN=please-change-me
API_HOST=0.0.0.0
API_PORT=8080
